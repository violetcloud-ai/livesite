    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "Draw_Data = IN[0];",
      "Id": "2cf8667b63254d8aba39c96c21482d18",
      "Inputs": [
        {
          "Id": "0974c3c57d9a46dc908e7c4994c6e85c",
          "Name": "IN",
          "Description": "IN",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "2f72ec05125344659186017edc56e969",
          "Name": "",
          "Description": "Draw_Data",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport math\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ndataEnteringNode = IN\r\n\r\nDraw_Data = IN[0]\r\nShow_Ctrl = IN[1]\r\nShow_Ld, Show_Dim, Show_AFD, Show_SFD, Show_BMD, Show_Rct = Show_Ctrl\r\n\r\nDraw_Obj = []\r\nColour_Obj = [[] for i in range(0,3)]\r\nText_Obj = [[] for j in range(0,3)]\r\n\r\ndef Colour_Code(Colour_Name):\r\n    Colour_Code = [ [255,0,0], [255,0,255], [0,0,255], [0,255,255], [0,255,0], \r\n    \t\t\t\t[255,255,0], [130, 100, 255], [75, 200, 200], [0, 100, 0],\r\n                    [255,130,0], [0,0,0], [255,255,255], [0,130,0], [255,180,180], [125, 125, 125]]       \r\n    Colour_List = [ \"Red\", \"Purple\", \"Blue\", \"Teal\", \"Green\", \r\n    \t\t\t\t\"Yellow\", \"Violet\", \"Turquoise\", \"Forest\",\r\n                    \"Orange\", \"Black\", \"White\", \"Basil\", \"Pink\", \"Grey\"]\r\n    Def_Colour = [0,0,0] #\"Black\"\r\n    if Colour_Name in Colour_List: n = Colour_List.index(Colour_Name); Output = Colour_Code[n]\r\n    else: Output = Def_Colour\r\n    return Output\r\n    \r\ndef Draw_Pt(Cd):\r\n    return Point.ByCoordinates(Cd[0], Cd[1], Cd[2])\r\n    \r\ndef Draw_Vn(VN): #reminder to adjust to global angle\r\n    return Vector.ByCoordinates(VN[0], VN[1], VN[2])\r\n    \r\ndef Draw_Pts(Cds):\r\n    Pts = []\r\n    for i in range(0,len(Cds)): Pts += [Point.ByCoordinates(Cds[i][0], Cds[i][1], Cds[i][2])]\r\n    return Pts\r\n    \r\ndef Draw_Colour(Colour_Name, Colour_Obj):\r\n    R_Col, G_Col, B_Col = Colour_Code(Colour_Name)\r\n    Colour_Obj[0] += [R_Col]\r\n    Colour_Obj[1] += [G_Col]\r\n    Colour_Obj[2] += [B_Col]\r\n\r\n\r\nDraw_Ref = [\"Framing\", \"Applied Loads\", \"Internal Forces\", \"Reactions\", \"Dimensions\"]\r\nfor r in range(0,len(Draw_Ref)):\r\n\tShow = 0\r\n\tif r == 0: Show = 1\r\n\tif r == 1 and Show_Ld == True: Show = 1\r\n\telif r == 2 and (Show_AFD == True or Show_SFD == True or Show_BMD == True): Show = 1\r\n\telif r == 3 and Show_Rct == True: Show = 1\r\n\telif r == 4 and Show_Dim == True: Show = 1\r\n\tif Show == 1:\r\n\t\tfor i in range(0,len(Draw_Data[r])):\r\n\t\t\tType = Draw_Data[r][i][0]\r\n\t\t\tif Type == \"Text\":\r\n\t\t\t\tType, Name, MText, Jt_t, Jt_D = Draw_Data[r][i]\r\n\t\t\t\tShow_Text = 1\r\n\t\t\t\tif r == 2:\r\n\t\t\t\t\tShow_Text = 0\r\n\t\t\t\t\tif Name == \"AFD\" and Show_AFD == True: Show_Text = 1\r\n\t\t\t\t\tif Name == \"SFD\" and Show_SFD == True: Show_Text = 1\r\n\t\t\t\t\tif Name == \"BMD\" and Show_BMD == True: Show_Text = 1\r\n\t\t\t\tif Show_Text == 1:\r\n\t\t\t\t\tText_Obj[0] += [Draw_Pt(Jt_D)]\r\n\t\t\t\t\tText_Obj[1] += [Draw_Pt(Jt_t)]\r\n\t\t\t\t\tif isinstance(MText, float) == True: Text_Obj[2] += [str(int(MText))]\r\n\t\t\t\t\telse: Text_Obj[2] += [str(MText)] \r\n\t\t\t\t\r\n\t\t\telif Type == \"Circle\" or Type == \"Joint\":\r\n\t\t\t\tType, Name, Colour, Circle_Rad, Dir, Jt_0 = Draw_Data[r][i]\r\n\t\t\t\tVector = Draw_Vn(Dir)\r\n\t\t\t\tPt_0 = Draw_Pt(Jt_0)\r\n\t\t\t\tCircle = Circle.ByCenterPointRadiusNormal(Pt_0, Circle_Rad, Vector)\r\n\t\t\t\tDraw_Obj += [Circle]\r\n\t\t\t\tDraw_Colour(Colour, Colour_Obj)\r\n\t\t\t\t\r\n\t\t\telif Type in [\"Line\", \"Outline\", \"AFD\", \"SFD\", \"BMD\"]:\r\n\t\t\t\tType, Name, Colour, Cyl_Rad, Jt_1, Jt_2 = Draw_Data[r][i]\r\n\t\t\t\tPt_1 = Draw_Pt(Jt_1); Pt_2 = Draw_Pt(Jt_2)\r\n\t\t\t\tDraw_Line = 1\r\n\t\t\t\tif r == 2:\r\n\t\t\t\t\tDraw_Line = 0\r\n\t\t\t\t\tif Type == \"AFD\" and Show_AFD == True: Draw_Line = 1\r\n\t\t\t\t\tif Type == \"SFD\" and Show_SFD == True: Draw_Line = 1\r\n\t\t\t\t\tif Type == \"BMD\" and Show_BMD == True: Draw_Line = 1\r\n\t\t\t\tif Draw_Line == 1:\r\n\t\t\t\t\tDraw_Obj += [Line.ByStartPointEndPoint(Pt_1, Pt_2)] \r\n\t\t\t\t\tDraw_Colour(Colour, Colour_Obj)\r\n\t\t\t\r\n\t\t\telif Type == \"Cuboid\":\r\n\t\t\t\tType, Name, Colour, Mbr_Pts, Mbr_Dir = Draw_Data[r][i]\r\n\t\t\t\tPts = Draw_Pts(Mbr_Pts)\r\n\t\t\t\tVC = Draw_Vn(Mbr_Dir)\r\n\t\t\t\tPL = Polygon.ByPoints(Pts)\r\n\t\t\t\tDraw_Obj += [Curve.ExtrudeAsSolid(PL, VC)]\r\n\t\t\t\tDraw_Colour(Colour, Colour_Obj)\r\n\t\t\t\t\r\n\t\t\telif Type == \"Sphere\":\r\n\t\t\t\tType, Name, Colour, Sphere_Rad, Jt_0 = Draw_Data[r][i]\r\n\t\t\t\tPt_0 = Draw_Pt(Jt_0)\r\n\t\t\t\tDraw_Obj += [Sphere.ByCenterPointRadius(Pt_0, Sphere_Rad)]\r\n\t\t\t\tDraw_Colour(Colour, Colour_Obj)\r\n\t\t\t\t\r\n# Assign your output to the OUT variable.\r\n\r\nOUT = [Draw_Obj, Colour_Obj, Text_Obj]",
      "VariableInputPorts": true,
      "Id": "5ef31257532046c3a616ae2e4b8ff5f9",
      "Inputs": [
        {
          "Id": "f33aa91a160648c7b2e414894044a455",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "77d85d66da364953ba334410d2ee69b7",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "a267f193fb42410099c7ec9494296e7f",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded IronPython script."
    },
