    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Enable Python support and load DesignScript library\r\nimport clr\r\nimport math\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ndataEnteringNode = IN\r\n\r\n# Place your code below this line\r\nShow_Ex = int(IN[0][0])\r\nForce_Scale = IN[0][1:]\r\nExamples = IN[1]\r\nJt_Info, Mbr_Info = Examples[Show_Ex-1]\r\n\r\nText_Size = 420\r\nText_Shift_r = 0.3\r\nDynamo_Offset = 0.9*Text_Size\r\nModel_Size = 100\r\nDim_D = Model_Size\r\nDim_B = Model_Size\r\nSphere_Rad = Model_Size\r\nd0_Tol = 5 * math.pi/180.0 #deg to rad\r\ndL_Tol = 10 #in mm\r\ndr_Tol = 0.001\r\n\r\nDraw_Ref = [\"Framing\", \"Applied Loads\", \"Internal Forces\", \"Reactions\", \"Dimensions\"]\r\nDraw_Data = [[] for i in range(0,len(Draw_Ref))]\r\n\r\n############################## Control Functions ########################################\r\ndef Frame_Analysis(Jt_List, Mbr_List):\r\n    ind_Name, ind_Res, ind_Jt, ind_Force, ind_React, ind_Defl, ind_Int_F = 0, 1, 2, 3, 4, 5, 5; DOF = 3\r\n    #Joint numbering references and 0 terms\r\n    Jt_Lib = []\r\n    for i in range(0,len(Jt_List)):\r\n        Jt_Lib += [Jt_List[i][ind_Name]]\r\n        Ini_Reaction = [0,0,0]\r\n        Ini_Defl = [0,0,0]\r\n        Jt_List[i] += [Ini_Reaction, Ini_Defl]\r\n    #Global K\r\n    Gl_K = [[0 for j in range(0,len(Jt_List)*DOF)] for i in range(0,len(Jt_List)*DOF)]\r\n    for j in range(0,len(Mbr_List)):\r\n        Mbr_Name, Name_i, Name_j, Mbr_UDL, Mat_Prop = Mbr_List[j]\r\n        Ini_Int_F = [0,0,0,0,0,0]\r\n        Mbr_List[j] += [Ini_Int_F]\r\n        ind_i = Jt_Lib.index(Name_i); Jt_i = Jt_List[ind_i][ind_Jt]\r\n        ind_j = Jt_Lib.index(Name_j); Jt_j = Jt_List[ind_j][ind_Jt]\r\n        V_n, M_n = End_Forces(Jt_i, Jt_j, Mbr_UDL)\r\n        Mbr_F = [0.0, V_n, M_n, 0.0, V_n, -M_n]\r\n        Gl_Mbr_F = Transform_Forces(\"Global\", Jt_i, Jt_j, Mbr_F)\r\n        Jt_List[ind_i][ind_Force][0] -= Gl_Mbr_F[0]\r\n        Jt_List[ind_i][ind_Force][1] -= Gl_Mbr_F[1]\r\n        Jt_List[ind_i][ind_Force][2] -= Gl_Mbr_F[2]\r\n        Jt_List[ind_j][ind_Force][0] -= Gl_Mbr_F[3]\r\n        Jt_List[ind_j][ind_Force][1] -= Gl_Mbr_F[4]\r\n        Jt_List[ind_j][ind_Force][2] -= Gl_Mbr_F[5]\r\n        Lc_K = Plane_K(Jt_i, Jt_j, Mat_Prop) #in kN, m\r\n        for p in range(0,len(Lc_K)):\r\n            for q in range(0,len(Lc_K[p])):\r\n                if p > 2: ii = ind_j*DOF + p - DOF  \r\n                else: ii = ind_i*DOF + p\r\n                if q > 2: jj = ind_j*DOF + q - DOF\r\n                else: jj = ind_i*DOF + q\r\n                Gl_K[ii][jj] += Lc_K[p][q]\r\n    #Joint numbering references and 0 terms\r\n    Gl_F, Gl_K_null = [], []\r\n    for i in range(0,len(Jt_List)):\r\n        Jt_Force = Jt_List[i][ind_Force]\r\n        Jt_Res = Jt_List[i][ind_Res]\r\n        for j in range(0,DOF):\r\n            if Jt_Res[j] == \"R\": Gl_K_null += [i*DOF + j]\r\n            else: Gl_F += [[Jt_Force[j]]] \r\n    #Global K for Unrestrained DOF\r\n    Gl_K_mod, Gl_ind = [], []\r\n    for i in range(0,len(Gl_K)):\r\n        if i not in Gl_K_null:\r\n            Gl_K_row = []\r\n            for j in range(0,len(Gl_K[i])):\r\n                if j not in Gl_K_null:\r\n                    Gl_K_row += [Gl_K[i][j]]\r\n            Gl_K_mod += [Gl_K_row]; Gl_ind += [i]\r\n    #Global Displacement/Rotation\r\n    Inv_K = Matrix_Inv_LU(Gl_K_mod)\r\n    Gl_D = Matrix_Mult(Inv_K, Gl_F) #in m, rad\r\n    for i in range(0,len(Jt_List)):\r\n        for j in range(0,3):\r\n            ind = i*DOF + j\r\n            for q in range(0,len(Gl_D)):\r\n                if ind == Gl_ind[q]: Jt_List[i][ind_Defl][j] = Gl_D[q][0]; break\r\n    #Local Forces\r\n    for j in range(0,len(Mbr_List)):\r\n        Mbr_Name, Name_i, Name_j, Mbr_UDL, Mat_Prop, Int_F = Mbr_List[j]\r\n        ind_i = Jt_Lib.index(Name_i); Jt_i = Jt_List[ind_i][ind_Jt]\r\n        ind_j = Jt_Lib.index(Name_j); Jt_j = Jt_List[ind_j][ind_Jt]\r\n        Lc_K = Plane_K(Jt_i, Jt_j, Mat_Prop)\r\n        Lc_D = [[0] for p in range(0,2*DOF)]\r\n        for p in range(0,DOF*2):\r\n            Lc_ind = ind_i*DOF + p\r\n            if p > 2: Lc_ind = ind_j*DOF + p - DOF  \r\n            for q in range(0,len(Gl_D)):\r\n                if Lc_ind == Gl_ind[q]: Lc_D[p] = Gl_D[q]; break\r\n        #Global/Local Internal Forces\r\n        Gl_M_F = Matrix_Mult(Lc_K, Lc_D)\r\n        Gl_M_Fr = []\r\n        for p in range(0,len(Gl_M_F)): Gl_M_Fr += [Gl_M_F[p][0]]\r\n        Lc_M_F = Transform_Forces(\"Local\", Jt_i, Jt_j, Gl_M_Fr)\r\n        V_n, M_n = End_Forces(Jt_i, Jt_j, Mbr_UDL)\r\n        Lc_Jt_F = [0.0, V_n, M_n, 0.0, V_n, -M_n]\r\n        Lc_F_r = [] \r\n        for p in range(0,len(Lc_M_F)): Mbr_List[j][ind_Int_F][p] += (Lc_M_F[p] + Lc_Jt_F[p])\r\n        #Reactions\r\n        Lc_F_r = Mbr_List[j][ind_Int_F]\r\n        Gl_F_r = Transform_Forces(\"Global\", Jt_i, Jt_j, Lc_F_r)\r\n        for i in range(0,len(Lc_F_r)): \r\n            if i > 2: Jt_List[ind_j][ind_React][i-DOF] += Gl_F_r[i]\r\n            else: Jt_List[ind_i][ind_React][i] += Gl_F_r[i]\r\n    return Mbr_List, Inv_K, Gl_K_mod, Gl_D, Gl_F\r\n\r\n\r\ndef Frame_Draw(Action, Jt_List, Mbr_List, Force_Scale, Draw_Data):\r\n    ind_Name, ind_Res, ind_Jt, ind_Force, ind_React = 0, 1, 2, 3, 4; DOF = 3\r\n    Jt_Lib = []; X_Store, Z_Store = [], [] #Y_Store = []\r\n    for i in range(0,len(Jt_List)):\r\n        Jt_Name = Jt_List[i][ind_Name]\r\n        Coord = Jt_List[i][ind_Jt]\r\n        Jt_Lib += [Jt_List[i][ind_Name]]\r\n        X_Store += [Coord[0]] #Y_Store += [Coord[1]]\r\n        Z_Store += [Coord[2]]\r\n    X_min, X_max, Z_min, Z_max = min(X_Store), max(X_Store), min(Z_Store), max(Z_Store)\r\n    d_X = X_max - X_min \r\n    d_Z = Z_max - Z_min  \r\n    if Action == \"Initial\":\r\n        #Titles\r\n        Title_List = [\"Model & Dimensions:\", \"Reactions & Deformation:\", \"Axial Force Diagram (AFD):\", \"Shear Force Diagram (SFD):\", \"Bending Moment Diagram (BMD):\"]\r\n        Draw_ind_List = [\"Dimensions\", \"Reactions\", \"Internal Forces\", \"Internal Forces\", \"Internal Forces\"]\r\n        Name_ind_List = [\"Model\", \"Reaction\", \"AFD\", \"SFD\", \"BMD\"]\r\n        for p in range(0,len(Title_List)):\r\n            Jt_m = [0, 0, Z_min + d_Z + 5000 - Text_Size * p]\r\n            MText = Title_List[p]\r\n            Text_Info = [Jt_m, MText, Draw_ind_List[p]]\r\n            Draw_Text(Name_ind_List[p], \"Title\", Text_Info, Draw_Data)\r\n        #Model X & Z Dimensions\r\n        Colour = \"Violet\"; Gap = 500; Leader = 500; Ext = 250; Arrow_Size = 250\r\n        Draw_Type = \"Dimensions\"\r\n        Dim_Info = Draw_Type, Colour, Gap, Leader, Ext, Arrow_Size\r\n        X_Set = sorted(set(X_Store))\r\n        Z_Set = sorted(set(Z_Store))\r\n        for i in range(0,len(X_Set)-1): #Dimension in X\r\n            Jt_i = [X_Set[i], 0, Z_Set[0]]\r\n            Jt_j = [X_Set[i+1], 0, Z_Set[0]]\r\n            Draw_Dimension(Jt_i, Jt_j, Dim_Info, Draw_Data)\r\n        for j in range(0,len(Z_Set)-1): #Dimension in Z\r\n            Jt_i = [X_Set[0], 0, Z_Set[j]]\r\n            Jt_j = [X_Set[0], 0, Z_Set[j+1]]\r\n            Draw_Dimension(Jt_i, Jt_j, Dim_Info, Draw_Data)\r\n        #Draw Joints and Joint Loads\r\n        for i in range(0,len(Jt_List)): #Joints\r\n            Jt_Name, Restraint, Coord, Forces = Jt_List[i]\r\n            Colour = \"Black\"; Supp_Size = 250; Jt_0 = Coord\r\n            Draw_Info = [Jt_Name, Colour, Supp_Size, Restraint]\r\n            Draw_Support(\"Model\", Jt_0, Draw_Info, Draw_Data)\r\n            Colour = \"Blue\"; Force_Dir = \"L\"\r\n            if Coord[0] > (X_min + d_X/2.0): Force_Dir = \"R\"\r\n            Draw_Info = [Jt_Name, Colour, Coord, Forces, Arrow_Size, Force_Dir]\r\n            Ansys_Loads(\"Model Joint\", Draw_Info, Draw_Data)\r\n        #Draw Frame Members and Frame Loads\r\n        for j in range(0,len(Mbr_List)): #Frames\r\n            Mbr_Name, Name_i, Name_j, Mbr_UDL, Mat_Prop = Mbr_List[j]\r\n            Colour = \"Black\"; Cyl_Rad = 100\r\n            ind_i = Jt_Lib.index(Name_i); Jt_1 = Jt_List[ind_i][ind_Jt]\r\n            ind_j = Jt_Lib.index(Name_j); Jt_2 = Jt_List[ind_j][ind_Jt]\r\n            Member_Info = [Mbr_Name, Colour, Cyl_Rad, Jt_1, Jt_2]\r\n            Frame_Member(\"Model\", Member_Info, Draw_Data) #Allow for Model option, 3D\r\n            Colour = \"Blue\"\r\n            Draw_Info = [Mbr_Name, Colour, Jt_1, Jt_2, Mbr_UDL, Arrow_Size]\r\n            Ansys_Loads(\"Model Member\", Draw_Info, Draw_Data)\r\n    elif Action == \"Results\":\r\n        #Draw Reaction\r\n        for i in range(0,len(Jt_List)):\r\n            Arrow_Size = 250\r\n            Jt_Name, Restraint, Coord, Forces, Reaction, Defl = Jt_List[i]\r\n            Colour = \"Red\"\r\n            React_Dir = \"L\"\r\n            if Coord[0] > (X_min + d_X/2.0): React_Dir = \"R\"\r\n            Draw_Info = [Jt_Name, Colour, Coord, Reaction, Defl, Restraint, Arrow_Size, React_Dir]\r\n            Ansys_Loads(\"Model Reaction\", Draw_Info, Draw_Data)\r\n        #Draw Axial Force Diagram, Shear Force Diagram, Bending Moment Diagram\r\n        for j in range(0,len(Mbr_List)):\r\n            Mbr_Name, Name_i, Name_j, Mbr_UDL, Mat_Prop, Mbr_Forces = Mbr_List[j]\r\n            ind_i = Jt_Lib.index(Name_i); Jt_1 = Jt_List[ind_i][ind_Jt]\r\n            ind_j = Jt_Lib.index(Name_j); Jt_2 = Jt_List[ind_j][ind_Jt]\r\n            Draw_Info = [Mbr_Name, Mbr_UDL, Mbr_Forces, Force_Scale]\r\n            Ansys_Internal_Forces(\"Model Axial\", Jt_1, Jt_2, Draw_Info, Draw_Data)\r\n            Ansys_Internal_Forces(\"Model Shear\", Jt_1, Jt_2, Draw_Info, Draw_Data)\r\n            Ansys_Internal_Forces(\"Model Bending\", Jt_1, Jt_2, Draw_Info, Draw_Data)\r\n\r\n############################## Structural Analysis Functions ########################################\r\n\r\ndef Transform_Forces(Action, Jt_i, Jt_j, Force_Matrix):\r\n    if Action == \"Global\": Angle_B = Plane_Angle(Jt_i, Jt_j)\r\n    else: Angle_B = -Plane_Angle(Jt_i, Jt_j)\r\n    P_i, V_i, M_i, P_j, V_j, M_j = Force_Matrix\r\n    TP_i, Dummy, TV_i = Plane_Rot(P_i, 0, V_i, Angle_B)\r\n    TP_j, Dummy, TV_j = Plane_Rot(P_j, 0, V_j, Angle_B)  \r\n    Output = [TP_i, TV_i, M_i, TP_j, TV_j, M_j]\r\n    return Output\r\n\r\ndef End_Forces(Jt_i, Jt_j, Mbr_UDL):        \r\n    Len = Dist(Jt_i, Jt_j)\r\n    V_n = Mbr_UDL * Len / 2.0 / 1000 #in kN\r\n    M_n = Mbr_UDL * Len**2 / 12.0 / 1000**2 #in kNm\r\n    return V_n, M_n\r\n    \r\ndef Plane_K(Jt_i, Jt_j, Mat_Prop): #Stiffness Matrix, XZ Plane\r\n    E_m, A_m, I_m = Mat_Prop #in MPa, mm2, mm4\r\n    L_m = Dist(Jt_i, Jt_j) #in mm\r\n    E_m = E_m*1.0 * 1000 #MPa to kPa\r\n    A_m = A_m*1.0 / 1000**2 #to m2\r\n    I_m = I_m*1.0 / 1000**4 #to m4\r\n    L_m = L_m*1.0 / 1000 #to m\r\n    Angle_B = Plane_Angle(Jt_i, Jt_j)\r\n    n_ix = math.cos(Angle_B) \r\n    n_iy = math.sin(Angle_B)\r\n    n_jx = math.cos(Angle_B)\r\n    n_jy = math.sin(Angle_B)\r\n\r\n    P_cf = (1.0 * A_m * E_m) / L_m\r\n    V_cf = (12.0 * E_m * I_m) / (L_m**3)\r\n    M_cf = (6.0 * E_m * I_m) / (L_m**2)\r\n    R_cf = (2.0 * E_m * I_m) / L_m\r\n    \r\n    PiPi =  P_cf*n_ix**2   + V_cf*n_iy**2\r\n    PiVi =  P_cf*n_ix*n_iy - V_cf*n_ix*n_iy\r\n    PiMi = -M_cf*n_iy\r\n    PiPj = -P_cf*n_ix*n_jx - V_cf*n_iy*n_jy\r\n    PiVj = -P_cf*n_ix*n_jy + V_cf*n_iy*n_jx\r\n    PiMj = -M_cf*n_iy\r\n    \r\n    ViPi =  P_cf*n_ix*n_iy - V_cf*n_ix*n_iy\r\n    ViVi =  P_cf*n_iy**2   + V_cf*n_ix**2\r\n    ViMi =  M_cf*n_ix\r\n    ViPj = -P_cf*n_iy*n_jx + V_cf*n_ix*n_jy\r\n    ViVj = -P_cf*n_iy*n_jy - V_cf*n_ix*n_jx\r\n    ViMj =  M_cf*n_ix\r\n    \r\n    MiPi = -M_cf*n_iy\r\n    MiVi =  M_cf*n_ix\r\n    MiMi =  2.0*R_cf\r\n    MiPj =  M_cf*n_jy\r\n    MiVj = -M_cf*n_jx\r\n    MiMj =  R_cf\r\n    \r\n    PjPi = -P_cf*n_ix*n_jx - V_cf*n_iy*n_jy\r\n    PjVi = -P_cf*n_iy*n_jx + V_cf*n_ix*n_jy\r\n    PjMi =  M_cf*n_jy\r\n    PjPj =  P_cf*n_jx**2   + V_cf*n_jy**2\r\n    PjVj =  P_cf*n_jx*n_jy - V_cf*n_jx*n_jy\r\n    PjMj =  M_cf*n_jy\r\n    \r\n    VjPi = -P_cf*n_ix*n_jy + V_cf*n_iy*n_jx\r\n    VjVi = -P_cf*n_iy*n_jy - V_cf*n_ix*n_jx\r\n    VjMi = -M_cf*n_jx\r\n    VjPj =  P_cf*n_jx*n_jy - V_cf*n_jx*n_jy\r\n    VjVj =  P_cf*n_jy**2   + V_cf*n_jx**2\r\n    VjMj = -M_cf*n_jx\r\n    \r\n    MjPi = -M_cf*n_iy\r\n    MjVi =  M_cf*n_ix\r\n    MjMi =  R_cf\r\n    MjPj =  M_cf*n_jy\r\n    MjVj = -M_cf*n_jx\r\n    MjMj =  2.0*R_cf\r\n\r\n    Pi_ij = [PiPi, PiVi, PiMi, PiPj, PiVj, PiMj]\r\n    Vi_ij = [ViPi, ViVi, ViMi, ViPj, ViVj, ViMj]\r\n    Mi_ij = [MiPi, MiVi, MiMi, MiPj, MiVj, MiMj]\r\n    Pj_ij = [PjPi, PjVi, PjMi, PjPj, PjVj, PjMj]\r\n    Vj_ij = [VjPi, VjVi, VjMi, VjPj, VjVj, VjMj]\r\n    Mj_ij = [MjPi, MjVi, MjMi, MjPj, MjVj, MjMj]\r\n     \r\n    K_Matrix = [Pi_ij, Vi_ij, Mi_ij, Pj_ij, Vj_ij, Mj_ij] #Units in kN, m\r\n    return K_Matrix\r\n\r\n\r\ndef Matrix_Mult(M1, M2):\r\n    M3 = [[0 for j in range(0,len(M2[0]))] for i in range(0,len(M1))] \r\n    for i in range(0,len(M3)):\r\n        for j in range(0,len(M3[i])):\r\n            Val_M3 = 0\r\n            for p in range(0,len(M1[0])):\r\n                Val_M1 = M1[i][p]\r\n                Val_M2 = M2[p][j]\r\n                Val_M3 += Val_M1 * Val_M2\r\n            M3[i][j] = Val_M3\r\n    return M3\r\n\r\n\r\ndef Matrix_Inv_Tri(Type, M):\r\n    M_r = [[0 for j in range(0,len(M[i])*2)] for i in range(0,len(M))]\r\n    for i in range(0,len(M)): \r\n        M_r[i][len(M)+i] = 1.0\r\n        for j in range(0,len(M[i])): M_r[i][j] = M[i][j]\r\n    if Type == \"Upper\": \r\n        for i in range(0,len(M_r)): \r\n            ind = len(M_r)-1-i; Coeff = 1.0*M_r[ind][ind]\r\n            for j in range(0,len(M_r[i])): M_r[ind][j] = M_r[ind][j] / Coeff\r\n            for p in range(0,i):\r\n                ind_n = ind+p+1; Coeff = 1.0*M_r[ind][ind_n]\r\n                for q in range(0,len(M_r[ind])): M_r[ind][q] -= Coeff * M_r[ind_n][q]\r\n    elif Type == \"Lower\":\r\n        for i in range(0,len(M_r)): \r\n            Coeff = 1.0*M_r[i][i]\r\n            for j in range(0,len(M_r[i])): M_r[i][j] = M_r[i][j] / Coeff\r\n            for p in range(0,i):\r\n                ind_n = i-p-1; Coeff = 1.0*M_r[i][ind_n]\r\n                for q in range(0,len(M_r[i])): M_r[i][q] -= Coeff * M_r[ind_n][q]\r\n    M_inv = [[0 for j in range(0,len(M[i]))] for i in range(0,len(M))]\r\n    for i in range(0,len(M)): \r\n        for j in range(0,len(M[i])): M_inv[i][j] = M_r[i][j+len(M)]\r\n    return M_inv \r\n\r\n\r\ndef Matrix_Inv_LU(M):\r\n    L_r = [[0 for j in range(0,len(M[i]))] for i in range(0,len(M))]\r\n    U_r = [[0 for j in range(0,len(M[i]))] for i in range(0,len(M))]\r\n    for i in range(0,len(M)): \r\n        U_r[0][i] = M[0][i]\r\n        for j in range(0,len(M[i])): \r\n            if i == j: L_r[i][j] = 1.0\r\n            elif j == 0: L_r[i][j] = M[i][j] / U_r[0][0]\r\n    for i in range(1,len(M)):\r\n        for j in range(0,len(M[i])):\r\n            if j >= i: \r\n                U_0 = 0\r\n                for p in range(0,i): U_0 += L_r[i][0+p] * U_r[0+p][j]\r\n                U_r[i][j] = M[i][j] - U_0 \r\n            if j < i and j > 0:\r\n                L_0 = 0\r\n                for q in range(0,j): L_0 += L_r[i][0+q] * U_r[0+q][j]\r\n                L_r[i][j] = (M[i][j] - L_0) / U_r[j][j]\r\n    U_inv = Matrix_Inv_Tri(\"Upper\", U_r)\r\n    L_inv = Matrix_Inv_Tri(\"Lower\", L_r) \r\n    M_inv = Matrix_Mult(U_inv, L_inv)\r\n    Output = M_inv\r\n    return Output\r\n\r\n############################## Spatial Manipulations ########################################\r\ndef Joint(Action, Input): \r\n    if Action == \"Add\":\r\n        Jt_n = Input[0]; d_Jts = Input[1:]; Jt_m = Jt_n; Jt_p = []\r\n        for i in range(0,len(d_Jts)):\r\n            Jt_p = [Jt_m[0] + d_Jts[i][0], Jt_m[1] + d_Jts[i][1], Jt_m[2] + d_Jts[i][2]]\r\n            Jt_m = Jt_p\r\n        return Jt_m\r\n    elif Action == \"Average\":\r\n        Jts = Input; Jt_X, Jt_Y, Jt_Z = [], [], []\r\n        for i in range(0,len(Jts)): \r\n            Jt_X += [Jts[i][0]*1.0]; Jt_Y += [Jts[i][1]*1.0]; Jt_Z += [Jts[i][2]*1.0]\r\n        Jt_Avg = [sum(Jt_X)/len(Jt_X), sum(Jt_Y)/len(Jt_Y), sum(Jt_Z)/len(Jt_Z)]\r\n        return Jt_Avg\r\n    elif Action == \"Difference\":\r\n        Jt_j, Jt_i = Input\r\n        Jt_n = [Jt_j[0] - Jt_i[0], Jt_j[1] - Jt_i[1], Jt_j[2] - Jt_i[2]]\r\n        return Jt_n\r\n\r\ndef Dist(Cd_i, Cd_j): #Distance between two joints\r\n    X_i, Y_i, Z_i = Cd_i; X_j, Y_j, Z_j = Cd_j\r\n    Length = math.sqrt((X_i*1.0 - X_j*1.0)**2 + (Y_i*1.0 - Y_j*1.0)**2 + (Z_i*1.0 - Z_j*1.0)**2)\r\n    return Length\r\n\r\ndef Intp(X_n, X_0, X_1, Y_0, Y_1): #Linear interpolation\r\n    Y_n = (Y_0 * (X_1 - X_n) + Y_1 * (X_n - X_0)) / (X_1 - X_0)\r\n    return Y_n\r\n\r\ndef Plane_Rot(dX, dY, dZ, A): #Local Coordinates XZ, returns XYZ (dY=0, Y=0)\r\n    dX_0 = dX*1.0*math.cos(A) - dZ*1.0*math.sin(A)\r\n    dZ_0 = dX*1.0*math.sin(A) + dZ*1.0*math.cos(A)\r\n    return [dX_0, 0, dZ_0]\r\n\r\ndef Plane_Angle(Cd_i, Cd_j): #Angle on XZ plane\r\n    X_i, Y_i, Z_i = Cd_i; X_j, Y_j, Z_j = Cd_j\r\n    d_X, d_Z = (X_j - X_i)*1.0, (Z_j - Z_i)*1.0\r\n    if d_X == 0 and d_Z >= 0: Angle_A = math.pi/2\r\n    elif d_X == 0 and d_Z < 0: Angle_A = 3*math.pi/2\r\n    elif d_X > 0 and d_Z >= 0: Angle_A = math.atan(d_Z/d_X)\r\n    elif d_X > 0 and d_Z < 0: Angle_A = 2*math.pi + math.atan(d_Z/d_X)\r\n    else: Angle_A = math.pi + math.atan(d_Z/d_X)\r\n    Angle_Output = (Angle_A * 180/math.pi % 360) * math.pi/180\r\n    return Angle_Output\r\n\r\n\r\n############################## Drawing Functions ########################################\r\ndef Draw_Arrow(Jt_i, Jt_j, Arrow_Size): #Jt_a at object, Jt_b away\r\n    Angle_B = Plane_Angle(Jt_i, Jt_j)\r\n    Arrow_Dp = Arrow_Size / 3.0\r\n    d_Zp = Plane_Rot(-Arrow_Size, 0.0, Arrow_Dp, Angle_B)\r\n    d_Zn = Plane_Rot(-Arrow_Size, 0.0, -Arrow_Dp, Angle_B)\r\n    Jt_a = Joint(\"Add\", [Jt_j, d_Zp])\r\n    Jt_b = Joint(\"Add\", [Jt_j, d_Zn])\r\n    return Jt_a, Jt_b\r\n\r\n\r\ndef Draw_Arc(Jt_0, Rad, Segments = 24, Start_0 = 0, Rot_0 = math.pi):\r\n    Jts = []\r\n    d_0 = Rot_0*1.0 / Segments\r\n    for i in range(0,Segments+1):\r\n        Angle = Start_0 + d_0 * i\r\n        Jt_n = Plane_Rot(Rad * math.cos(Angle), 0.0, Rad * math.sin(Angle), 0.0)\r\n        Jt_i = Joint(\"Add\", [Jt_0, Jt_n])\r\n        Jts += [Jt_i]\r\n    return Jts\r\n\r\n\r\ndef Draw_Dimension(Jt_i, Jt_j, Dim_Info, Draw_Data):\r\n    Angle_B = Plane_Angle(Jt_i, Jt_j)\r\n    Draw_ind, Colour, Gap, Leader, Ext, Arrow_Size = Dim_Info\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Action = \"Model\"\r\n    Type = \"Line\"\r\n    Name = \"Dimensions\"\r\n    Cyl_Rad = \"NA\"\r\n    if abs(Angle_B) <= d0_Tol or abs(Angle_B - math.pi) <= d0_Tol: Sign = -1.0\r\n    else: Sign = 1.0\r\n    d_H1 = Plane_Rot(0.0, 0.0, Sign * Gap, Angle_B)\r\n    d_H2 = Plane_Rot(0.0, 0.0, Sign * (Gap + Leader), Angle_B)\r\n    d_H3 = Plane_Rot(0.0, 0.0, Sign * (Gap + Leader + Ext), Angle_B)\r\n    Jt_i1 = Joint(\"Add\", [Jt_i, d_H1])\r\n    Jt_i2 = Joint(\"Add\", [Jt_i, d_H2])\r\n    Jt_i3 = Joint(\"Add\", [Jt_i, d_H3])\r\n    Jt_j1 = Joint(\"Add\", [Jt_j, d_H1])\r\n    Jt_j2 = Joint(\"Add\", [Jt_j, d_H2])\r\n    Jt_j3 = Joint(\"Add\", [Jt_j, d_H3])\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i1, Jt_i2]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i2, Jt_i3]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_j1, Jt_j2]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_j2, Jt_j3]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i2, Jt_j2]; Draw_Data[r] += [Draw_Info]\r\n    Jt_a, Jt_b = Draw_Arrow(Jt_i2, Jt_j2, Arrow_Size)\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_a, Jt_j2]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_b, Jt_j2]; Draw_Data[r] += [Draw_Info]\r\n    Jt_a, Jt_b = Draw_Arrow(Jt_j2, Jt_i2, Arrow_Size)\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_a, Jt_i2]; Draw_Data[r] += [Draw_Info]\r\n    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_b, Jt_i2]; Draw_Data[r] += [Draw_Info]\r\n    MText = str(int(Dist(Jt_i2, Jt_j2)))\r\n    Jt_m = Joint(\"Average\", [Jt_i2, Jt_j2])\r\n    if Angle_B <> 0: d_Text = [-2*Text_Shift_r*len(MText)*Text_Size, 0, 0]\r\n    else: d_Text = [-Text_Shift_r*len(MText)*Text_Size, 0, 0]\r\n    Jt_mr = Joint(\"Add\", [Jt_m, d_Text])\r\n    Text_Info = Jt_mr, MText, Draw_ind\r\n    Draw_Text(Action, \"Dimensions\", Text_Info, Draw_Data)\r\n\r\n\r\ndef Draw_Text(Action, Type, Text_Info, Draw_Data):\r\n    Jt_m, MText, Draw_ind = Text_Info\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Shift_X = -len(MText) * Text_Shift_r * Text_Size #Default centre\r\n    Shift_Y = 0; Shift_Z = 0\r\n    Name_Type = Type\r\n    if Type == \"Title\": Name_Type = Action; Shift_X = 0\r\n    elif Type == \"Member Load\": Shift_Z += 1.0 * Text_Size\r\n    elif Type == \"Joint Name\": MText = \"[\" + MText + \"]\"; Shift_X += 1.0 * Text_Size; Shift_Z += 1.0 * Text_Size\r\n    elif Type == \"Member Name V\": Shift_X = 0\r\n    elif Type == \"Member Name H\": Shift_X += Text_Size; Shift_Z += 1.5 * Text_Size\r\n    elif Type == \"BMD Max\": Name_Type = Type[:3]\r\n    elif Type == \"Result\": Shift_X = 0\r\n    elif Type == \"Applied Force\": Shift_X = Text_Size / 2.0; Shift_Z = Text_Size / 2.0\r\n    elif Type == \"Applied Moment\": Shift_Z = -Text_Size\r\n    elif Type == \"Dimensions\": Shift_X = 0\r\n    elif Type in [\"AFD i -\", \"SFD i -\", \"BMD i -\"]:\r\n        Name_Type = Type[:3]\r\n        Shift_X = Text_Size / 2.0\r\n        Shift_Z += -0.5 * Text_Size\r\n    elif Type in [\"AFD i +\", \"SFD i +\", \"BMD i +\"]:\r\n        Name_Type = Type[:3]\r\n        Shift_X = Text_Size / 2.0\r\n        Shift_Z += 0.5 * Text_Size\r\n    elif Type in [\"AFD j -\", \"SFD j -\", \"BMD j -\"]:\r\n        Name_Type = Type[:3]\r\n        Shift_X = -2 * len(MText) * Text_Shift_r * Text_Size\r\n        Shift_Z += -0.5 * Text_Size\r\n    elif Type in [\"AFD j +\", \"SFD j +\", \"BMD j +\"]:\r\n        Name_Type = Type[:3]\r\n        Shift_X = -2 * len(MText) * Text_Shift_r * Text_Size\r\n        Shift_Z += 0.5 * Text_Size\r\n    d_Jt_t = [Shift_X, Shift_Y, Shift_Z]\r\n    d_Jt_D = [0, 0, -Dynamo_Offset]\r\n    Jt_t = Joint(\"Add\", [Jt_m, d_Jt_t])\r\n    Jt_D = Joint(\"Add\", [Jt_t, d_Jt_D])\r\n    Draw_Info = [\"Text\", Name_Type, MText, Jt_t, Jt_D]; Draw_Data[r] += [Draw_Info]\r\n\r\n\r\ndef Draw_Support(Action, Jt_0, Draw_Info, Draw_Data):\r\n    Draw_ind = \"Framing\"\r\n    Name_ind = \"Dimensions\"\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Name, Colour, Size, Restraint = Draw_Info\r\n    MText = str(Name)\r\n    Text_Info = [Jt_0, MText, Name_ind]\r\n    Draw_Text(Action, \"Joint Name\", Text_Info, Draw_Data)\r\n    Cyl_Rad = \"NA\"\r\n    Solid_Colour = \"Orange\"\r\n    Draw_Info = [\"Sphere\", Name, Solid_Colour, Sphere_Rad, Jt_0]; Draw_Data[r] += [Draw_Info]\r\n    if Restraint == [\"R\", \"R\", \"R\"]: #Fixed\r\n        d_Xn = [-Size, 0, -Size/2.0]\r\n        d_Xp = [Size, 0, -Size/2.0]\r\n        Jt_1 = Joint(\"Add\", [Jt_0, d_Xn])\r\n        Jt_2 = Joint(\"Add\", [Jt_0, d_Xp])\r\n        Type = \"Line\"\r\n        Colour = \"Black\"\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n        Jt_12 = Joint(\"Average\", [Jt_1, Jt_2])\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_0, Jt_12]; Draw_Data[r] += [Draw_Info]\r\n    elif Restraint == [\"R\", \"R\", \"F\"] or Restraint == [\"F\", \"R\", \"F\"]: #Pinned, Roller\r\n        d_Jtn = [-Size, 0, -Size]\r\n        d_Jtp = [Size, 0, -Size]\r\n        Jt_1 = Joint(\"Add\", [Jt_0, d_Jtn])\r\n        Jt_2 = Joint(\"Add\", [Jt_0, d_Jtp])\r\n        Type = \"Line\"\r\n        Colour = \"Black\"\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_0, Jt_1]; Draw_Data[r] += [Draw_Info]\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_0, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n        Jt_0a = Joint(\"Average\", [Jt_1, Jt_2])\r\n        Jt_1a = Joint(\"Average\", [Jt_0a, Jt_1])\r\n        Jt_2a = Joint(\"Average\", [Jt_0a, Jt_2])\r\n        if Restraint == [\"F\", \"R\", \"F\"]:\r\n            Type = \"Circle\"\r\n            Colour = \"Black\"\r\n            Circle_Rad = Size/4.0\r\n            Dir = [0, 1, 0]\r\n            Jt_ref = [Jt_1a, Jt_2a]\r\n            for i in range(0,2):\r\n                d_Z = [0.0, 0.0, -Circle_Rad]\r\n                Jt_c = Joint(\"Add\", [Jt_ref[i], d_Z])\r\n                Draw_Info = [Type, Name, Colour, Circle_Rad, Dir, Jt_c]; Draw_Data[r] += [Draw_Info]  \r\n    if Restraint == [\"R\", \"R\", \"R\"] or Restraint == [\"R\", \"R\", \"F\"]: #Pinned\r\n        Type = \"Line\"\r\n        Segments = 4\r\n        d_L = 1.0*Dist(Jt_1, Jt_2) / Segments\r\n        d_S = [-d_L*2.0/3, 0, -d_L*2.0/3]  \r\n        for i in range(0,Segments):\r\n            d_Jt_1 = [d_L*i, 0, 0]\r\n            d_Jt_2 = [d_L*(i+1), 0, 0]\r\n            Jt_1b = Joint(\"Add\", [Jt_1, d_Jt_1])\r\n            Jt_2b = Joint(\"Add\", [Jt_1, d_Jt_2])\r\n            Jt_12 = Joint(\"Average\", [Jt_1b, Jt_2b])\r\n            Jt_23 = Joint(\"Add\", [Jt_12, d_S])\r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_12, Jt_23]; Draw_Data[r] += [Draw_Info]\r\n\r\n\r\ndef Ansys_UDL(Jt_1, Jt_2, Size, Segments = 10):\r\n    Angle_B = Plane_Angle(Jt_1, Jt_2)\r\n    d_Zi = Size + Text_Size\r\n    d_Jt_Z = Plane_Rot(0.0, 0.0, d_Zi, Angle_B)\r\n    Jt_1r = Joint(\"Add\", [Jt_1, d_Jt_Z])\r\n    Jt_2r = Joint(\"Add\", [Jt_2, d_Jt_Z])\r\n    d_L = Dist(Jt_1r, Jt_2r) * 1.0 / Segments\r\n    Jts = []\r\n    for i in range(0,Segments+1):\r\n        d_Jt_Li = Plane_Rot(d_L * i, 0.0, 0.0, Angle_B)\r\n        d_Jt_Lj = Plane_Rot(d_L * i, 0.0, -Size, Angle_B)\r\n        Jt_i = Joint(\"Add\", [Jt_1r, d_Jt_Li])\r\n        Jt_j = Joint(\"Add\", [Jt_1r, d_Jt_Lj])\r\n        Jts += [[Jt_i, Jt_j]]\r\n    return Jts\r\n\r\n\r\ndef Ansys_Loads(Action, Draw_Info, Draw_Data):\r\n    if Action == \"Model Reaction\": r = Draw_ind = \"Reactions\"; Text_Action = \"Model\"\r\n    else: Draw_ind = \"Applied Loads\"; Text_Action = \"Model\"\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Cyl_Rad = \"NA\"; Type = \"Line\"\r\n    if Action in [\"Model Member\"]:\r\n        Name, Colour, Jt_1, Jt_2, Mbr_UDL, Arrow_Size = Draw_Info\r\n        Shift = Arrow_Size; Arrow_Len = Arrow_Size * 2.5; Arrow_Head = Arrow_Size\r\n        if Mbr_UDL <> 0:\r\n            Segments = 10\r\n            UDL_Size = Arrow_Len\r\n            Jts = Ansys_UDL(Jt_1, Jt_2, UDL_Size, Segments)\r\n            Jt_i, Jt_j = Jts[0][0], Jts[-1][0]\r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n            Jt_m = Joint(\"Average\", [Jt_i, Jt_j])\r\n            MText = str(round(Mbr_UDL,2)) + \" kN/m\"\r\n            Text_Info = [Jt_m, MText, Draw_ind]\r\n            Draw_Text(Text_Action, \"Member Load\", Text_Info, Draw_Data)\r\n            for i in range(0,len(Jts)): #Jt_i, Jt_j = Jts[i]\r\n                if Mbr_UDL > 0: Jt_i, Jt_j = Jts[i]\r\n                else: Jt_j, Jt_i = Jts[i]\r\n                Jt_a, Jt_b = Draw_Arrow(Jt_i, Jt_j, Arrow_Head)\r\n                Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_a, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_b, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n    elif Action in [\"Model Joint\", \"Model Reaction\"]:\r\n        if Action == \"Model Joint\": \r\n            Name, Colour, Coord, Forces, Arrow_Size, Draw_Dir = Draw_Info\r\n            Restraint = [\"R\", \"R\", \"R\"] #Dummy\r\n            Start_0 = math.pi/4\r\n            Rot_0 = math.pi\r\n            Shift = Arrow_Size\r\n            Arrow_Len = Arrow_Size * 5.0\r\n            Arrow_Head = Arrow_Size\r\n        elif Action == \"Model Reaction\":\r\n            Name, Colour, Coord, Reaction, Defl, Restraint, Arrow_Size, Draw_Dir = Draw_Info\r\n            Forces = Reaction\r\n            if Reaction[-1] > 0: Start_0 = math.pi/2; Rot_0 = math.pi\r\n            else: Start_0 = math.pi/2; Rot_0 = -math.pi #* 5.0/4\r\n            Shift = Arrow_Size\r\n            Arrow_Len = Arrow_Size * 5.0\r\n            Arrow_Head = Arrow_Size\r\n            MText_List = [] #Reaction/Defl Text\r\n            for i in range(0,3):\r\n                if Restraint[i] == \"F\":\r\n                    if i == 0: MText = \"dx = \" + str(round(Defl[i]*1000,2)) + \" mm\"\r\n                    elif i == 1: MText = \"dy = \" + str(round(Defl[i]*1000,2)) + \" mm\"\r\n                    elif i == 2: MText = \"dr = \" + str(round(Defl[i]*1000,3)) + \" rad\"\r\n                    MText_List += [MText]\r\n                else:\r\n                    if i == 0: MText = \"Rx = \" + str(round(Reaction[i],1)) + \" kN\"\r\n                    elif i == 1: MText = \"Ry = \" + str(round(Reaction[i],1)) + \" kN\"\r\n                    elif i == 2: MText = \"M = \" + str(round(Reaction[i],1)) + \" kNm\" \r\n                    MText_List += [MText]\r\n            for i in range(0,3):\r\n                d_Jt_m = [Text_Size/2.0, 0, -Text_Size * (i+0.5)]\r\n                if \"R\" in Restraint and Draw_Dir == \"L\": d_Jt_m = [-(len(MText_List[-1])) *2* Text_Shift_r * Text_Size, 0, -Text_Size * (i+1)]\r\n                elif \"R\" in Restraint and Draw_Dir == \"R\": d_Jt_m = [Text_Size, 0, -Text_Size * (i+1)]     \r\n                Jt_m = Joint(\"Add\", [Coord, d_Jt_m])\r\n                MText = MText_List[i]\r\n                Text_Info = [Jt_m, MText, Draw_ind]\r\n                Draw_Text(Text_Action, \"Result\", Text_Info, Draw_Data)\r\n        for i in range(0,3):\r\n            if Forces[i] <> 0 and Restraint[i] == \"R\":\r\n                if i == 2:\r\n                    Rad = 500\r\n                    Segments = 24 #10\r\n                    Jts = Draw_Arc(Coord, Rad, Segments, Start_0, Rot_0)\r\n                    if \"Joint\" in Action:\r\n                        MText = str(round(Forces[i],2)) + \" kNm\"\r\n                        Text_Info = [Jt_m, MText, Draw_ind]\r\n                        Draw_Text(Text_Action, \"Applied Moment\", Text_Info, Draw_Data)\r\n                    for j in range(0,len(Jts)-1):\r\n                        Jt_i, Jt_j = Jts[j], Jts[j+1]\r\n                        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                        if j == 0:\r\n                            Jt_a, Jt_b = Draw_Arrow(Jt_j, Jt_i, Arrow_Head)\r\n                            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_a, Jt_i]; Draw_Data[r] += [Draw_Info]\r\n                            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_b, Jt_i]; Draw_Data[r] += [Draw_Info]\r\n                else:\r\n                    if i == 0: \r\n                        if Draw_Dir == \"R\": L_1 = Shift; L_2 = Shift + Arrow_Len\r\n                        else: L_2 = -Shift; L_1 = -(Shift + Arrow_Len)\r\n                        d_1 = [L_1, 0, 0]; d_2 = [L_2, 0, 0]\r\n                    else: \r\n                        if \"Reaction\" in Action: L_2 = -Shift; L_1 = -(Shift + Arrow_Len)\r\n                        else: L_1 = Shift; L_2 = Shift + Arrow_Len \r\n                        d_1 = [0, 0, L_1]; d_2 = [0, 0, L_2]\r\n                    Jt_1 = Joint(\"Add\", [Coord, d_1])\r\n                    Jt_2 = Joint(\"Add\", [Coord, d_2])\r\n                    Jt_i = Jt_2; Jt_j = Jt_1\r\n                    if Forces[i] > 0: Jt_i = Jt_1; Jt_j = Jt_2\r\n                    Jt_a, Jt_b = Draw_Arrow(Jt_i, Jt_j, Arrow_Head)\r\n                    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_a, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                    Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_b, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n                    if \"Joint\" in Action:\r\n                        MText = str(round(Forces[i],2)) + \" kN\"\r\n                        Jt_m = Jt_j #Calculate.Joint(\"Average\", [Jt_i, Jt_j])\r\n                        if Forces[i] < 0 or (Forces[i] > 0 and Draw_Dir == \"L\"): \r\n                            if i == 0: d_Jt_m = [-(len(MText)+1) * Text_Shift_r * Text_Size, 0, 0]\r\n                            else: d_Jt_m = [0,0,0]\r\n                            Jt_m = Joint(\"Add\", [Jt_i, d_Jt_m])\r\n                        Text_Info = [Jt_m, MText, Draw_ind]\r\n                        Draw_Text(Text_Action, \"Applied Force\", Text_Info, Draw_Data)\r\n                                \r\n                        \r\ndef Frame_Member(Action, Member_Info, Draw_Data, Mbr_Text = \"On\"):\r\n    Draw_ind = \"Framing\"; Name_ind = \"Dimensions\"\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Mbr_Name, Colour, Cyl_Rad, Jt_1, Jt_2 = Member_Info\r\n    Angle_B = Plane_Angle(Jt_1, Jt_2)\r\n    Type = \"Line\"\r\n    Draw_Info = [Type, Mbr_Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n    Solid_Colour = \"Orange\"\r\n    Mbr_Dir = Joint(\"Difference\", [Jt_2, Jt_1])\r\n    d_Dp = Plane_Rot(0.0, 0.0, Dim_D/2.0, Angle_B)\r\n    d_Dn = Plane_Rot(0.0, 0.0, -Dim_D/2.0, Angle_B)  \r\n    d_Bp = [0.0, Dim_B/2.0, 0.0]\r\n    d_Bn = [0.0, -Dim_B/2.0, 0.0]\r\n    Jt_A = Joint(\"Add\", [Jt_1, d_Dp, d_Bp])\r\n    Jt_B = Joint(\"Add\", [Jt_1, d_Dp, d_Bn])\r\n    Jt_C = Joint(\"Add\", [Jt_1, d_Dn, d_Bn])\r\n    Jt_D = Joint(\"Add\", [Jt_1, d_Dn, d_Bp])\r\n    Mbr_Jts = [Jt_A, Jt_B, Jt_C, Jt_D]\r\n    Draw_Info = [\"Cuboid\", Mbr_Name, Solid_Colour, Mbr_Jts, Mbr_Dir]; Draw_Data[r] += [Draw_Info]\r\n    if Mbr_Text == \"On\":\r\n        if abs(Angle_B) <= d0_Tol or abs(Angle_B - math.pi) <= d0_Tol: Text_Type = \"Member Name H\"\r\n        else: Text_Type = \"Member Name V\"\r\n        Jt_m = Joint(\"Average\", [Jt_1, Jt_2])\r\n        MText = str(Mbr_Name)\r\n        Text_Info = [Jt_m, MText, Name_ind]\r\n        Draw_Text(Action, Text_Type, Text_Info, Draw_Data)\r\n         \r\n       \r\ndef Ansys_Internal_Forces(Action, Jt_i, Jt_j, Draw_Info, Draw_Data):\r\n    Mbr_Name, Mbr_UDL, Mbr_Forces, Force_Scale = Draw_Info\r\n    Draw_ind = \"Internal Forces\"; Text_Action = \"Model\"\r\n    r = Draw_Ref.index(Draw_ind)\r\n    Angle_B = Plane_Angle(Jt_i, Jt_j)\r\n    AFD_Sign = 1.0 \r\n    SFD_Sign = 1.0 \r\n    BMD_Sign = -1.0 #Plot Negative on +Z Axis\r\n    Def_Scale = 100.0\r\n    P_Scale, V_Scale, M_Scale = Force_Scale\r\n    GP_i, GV_i, GM_i, GP_j, GV_j, GM_j = Mbr_Forces\r\n    P_i = 1.0 * GP_i; P_j = -1.0 * GP_j; V_i = 1.0 * GV_i; V_j = -1.0 * GV_j; M_i = -1.0 * GM_i; M_j = 1.0 * GM_j\r\n    d_Pi = Plane_Rot(0.0, 0.0, AFD_Sign * P_i * P_Scale * Def_Scale, Angle_B)  \r\n    d_Vi = Plane_Rot(0.0, 0.0, SFD_Sign * V_i * V_Scale * Def_Scale, Angle_B)  \r\n    d_Mi = Plane_Rot(0.0, 0.0, BMD_Sign * M_i * M_Scale * Def_Scale, Angle_B)  \r\n    d_Pj = Plane_Rot(0.0, 0.0, AFD_Sign * P_j * P_Scale * Def_Scale, Angle_B)  \r\n    d_Vj = Plane_Rot(0.0, 0.0, SFD_Sign * V_j * V_Scale * Def_Scale, Angle_B)  \r\n    d_Mj = Plane_Rot(0.0, 0.0, BMD_Sign * M_j * M_Scale * Def_Scale, Angle_B) \r\n    Name = Mbr_Name\r\n    Cyl_Rad = \"NA\"\r\n    if Action == \"Model Axial\":\r\n        Type = \"AFD\"\r\n        Colour = \"Green\"\r\n        Jt_1 = Joint(\"Add\", [Jt_i, d_Pi])\r\n        Jt_2 = Joint(\"Add\", [Jt_j, d_Pj])\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n        if Dist(Jt_1, Jt_i) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_1]; Draw_Data[r] += [Draw_Info]\r\n            if P_i > 0: Text_Type = \"AFD i +\"\r\n            else: Text_Type = \"AFD i -\"\r\n            MText = str(round(P_i,2)) + \" kN\"\r\n            Text_Info = [Jt_1, MText, Draw_ind]\r\n            Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n        if Dist(Jt_2, Jt_j) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_2, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n            if abs(P_i - P_j) > dr_Tol:\r\n                if P_j > 0: Text_Type = \"AFD j +\"\r\n                else: Text_Type = \"AFD j -\"\r\n                MText = str(round(P_j,2)) + \" kN\"\r\n                Text_Info = [Jt_2, MText, Draw_ind]\r\n                Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n    elif Action == \"Model Shear\":\r\n        Type = \"SFD\"\r\n        Colour = \"Blue\"\r\n        Jt_1 = Joint(\"Add\", [Jt_i, d_Vi])\r\n        Jt_2 = Joint(\"Add\", [Jt_j, d_Vj])\r\n        Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n        if Dist(Jt_1, Jt_i) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_1]; Draw_Data[r] += [Draw_Info]\r\n            if V_i > 0: Text_Type = \"SFD i +\"\r\n            else: Text_Type = \"SFD i -\"\r\n            MText = str(round(V_i,2)) + \" kN\"\r\n            Text_Info = [Jt_1, MText, Draw_ind]\r\n            Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n        if Dist(Jt_2, Jt_j) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_2, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n            if abs(V_i - V_j) > dr_Tol:\r\n                if V_j > 0: Text_Type = \"SFD j +\"\r\n                else: Text_Type = \"SFD j -\"\r\n                MText = str(round(V_j,2)) + \" kN\"\r\n                Text_Info = [Jt_2, MText, Draw_ind]\r\n                Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n    elif Action == \"Model Bending\":\r\n        Type = \"BMD\"\r\n        Colour = \"Red\"\r\n        Jt_1 = Joint(\"Add\", [Jt_i, d_Mi])\r\n        Jt_2 = Joint(\"Add\", [Jt_j, d_Mj])\r\n        if Dist(Jt_1, Jt_i) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_i, Jt_1]; Draw_Data[r] += [Draw_Info]\r\n            if M_i > 0: Text_Type = \"BMD i -\" #Plot on top\r\n            else: Text_Type = \"BMD i +\"\r\n            MText = str(round(M_i,2)) + \" kNm\"\r\n            Text_Info = [Jt_1, MText, Draw_ind]\r\n            Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n        if Dist(Jt_2, Jt_j) > dr_Tol: \r\n            Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_2, Jt_j]; Draw_Data[r] += [Draw_Info]\r\n            if M_j > 0: Text_Type = \"BMD j -\"\r\n            else: Text_Type = \"BMD j +\"\r\n            MText = str(round(M_j,2)) + \" kNm\"\r\n            Text_Info = [Jt_2, MText, Draw_ind]\r\n            Draw_Text(Text_Action, Text_Type, Text_Info, Draw_Data)\r\n        if Mbr_UDL <> 0: #Draw Quadratic BMD Curve\r\n            BMD_Abs = []\r\n            BMD_List = []\r\n            BMD_Jt = []\r\n            Segments = 8\r\n            Len = Dist(Jt_i, Jt_j) / 1000.0\r\n            d_L = Len*1.0 / Segments\r\n            for i in range(0,Segments):\r\n                M_1 = Intp(d_L*i, 0.0, Len, M_i, M_j)\r\n                M_2 = Intp(d_L*(i+1), 0.0, Len, M_i, M_j)\r\n                M_x1 = M_1 + Mbr_UDL * d_L*i / 2.0 * (Len - d_L*i)\r\n                M_x2 = M_2 + Mbr_UDL * d_L*(i+1) / 2.0 * (Len - d_L*(i+1))\r\n                d_M1 = Plane_Rot(0.0, 0.0, BMD_Sign * M_x1 * M_Scale * Def_Scale, Angle_B)  \r\n                d_M2 = Plane_Rot(0.0, 0.0, BMD_Sign * M_x2 * M_Scale * Def_Scale, Angle_B)  \r\n                d_1m = Plane_Rot(d_L*i * 1000.0, 0.0, 0.0, Angle_B) \r\n                d_2m = Plane_Rot(d_L*(i+1) * 1000.0, 0.0, 0.0, Angle_B) \r\n                Jt_1m = Joint(\"Add\", [Jt_i, d_1m, d_M1])\r\n                Jt_2m = Joint(\"Add\", [Jt_i, d_2m, d_M2])\r\n                Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1m, Jt_2m]; Draw_Data[r] += [Draw_Info]\r\n                if i < Segments-1: BMD_Abs += [abs(M_x2)]; BMD_List += [M_x2]; BMD_Jt += [Jt_2m]\r\n            BMD_List_Sort, BMD_Jt_Sort = zip(*sorted(zip(BMD_List, BMD_Jt)))\r\n            if BMD_List_Sort[0] < min(M_i, M_j):\r\n                MText = str(round(BMD_List_Sort[0],2)) + \" kNm\"\r\n                Jt_t = BMD_Jt_Sort[0]\r\n                Text_Info = [Jt_t, MText, Draw_ind]\r\n                Draw_Text(Text_Action, \"BMD Max\", Text_Info, Draw_Data)\r\n            if BMD_List_Sort[-1] > max(M_i, M_j):\r\n                MText = str(round(BMD_List_Sort[-1],2)) + \" kNm\"\r\n                Jt_t = BMD_Jt_Sort[-1]\r\n                Text_Info = [Jt_t, MText, Draw_ind]\r\n                Draw_Text(Text_Action, \"BMD Max\", Text_Info, Draw_Data)\r\n        else: Draw_Info = [Type, Name, Colour, Cyl_Rad, Jt_1, Jt_2]; Draw_Data[r] += [Draw_Info]\r\n\r\n    \r\n############################## Run Functions ########################################\r\n\r\nFrame_Draw(\"Initial\", Jt_Info, Mbr_Info, Force_Scale, Draw_Data)\r\n\r\nMbr_Info_r, Inv_K, Gl_K_f, Gl_D, Gl_F = Frame_Analysis(Jt_Info, Mbr_Info)\r\n\r\nFrame_Draw(\"Results\", Jt_Info, Mbr_Info_r, Force_Scale, Draw_Data)\r\n\r\nResults = [Inv_K, Gl_D, Gl_F, Jt_Info, Mbr_Info_r]\r\n\r\n# Assign your output to the OUT variable.\r\nOUT = Draw_Data, Results\r\n",
      "VariableInputPorts": true,
      "Id": "3a9aefff964a447db354d013bcadc1a0",
