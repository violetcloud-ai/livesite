    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "//Joint Data = [Name, Restraint (F=Free), Coord (XYZ mm), Jt PVM (kN,kN,kNm)]\nSet_X = 0;\nSet_Y = 0;\nJt_A = [\"A\", [\"R\", \"R\", \"R\"], [Set_X + 0, Set_Y, 0], [0, 0, 0]];\nJt_B = [\"B\", [\"F\", \"F\", \"F\"], [Set_X + 6000, Set_Y, 4500], [15.0, 0, 20.0]];\nJt_C = [\"C\", [\"F\", \"F\", \"F\"], [Set_X + 9000, Set_Y, 4500], [0, -10.0, 0]];\nJt_D = [\"D\", [\"R\", \"R\", \"R\"], [Set_X + 12000, Set_Y, 4500], [0, 0, 0]];\nJt_Info = [Jt_A, Jt_B, Jt_C, Jt_D];\n\n//Material Property = [Elastic Mod MPa, MOI mm4, Area mm2]\nE_m = 200000;\nI_m = 60*1000000;\nA_m = 600;\nProp = [E_m, A_m, I_m];\n\n//Member data = [Name, Jt_i, Jt_j, UDL (kN/m), Material Property]\nMbr_1 = [\"Mbr 1\", \"A\", \"B\", 3.0, Prop];\nMbr_2 = [\"Mbr 2\", \"B\", \"C\", 0.0, Prop];\nMbr_3 = [\"Mbr 3\", \"C\", \"D\", 0.0, Prop];\nMbr_Info = [Mbr_1, Mbr_2, Mbr_3];\n\n//Input Summary\nInput = [Jt_Info, Mbr_Info];",
      "Id": "eff8acbfbf894779aace99968abfaa0c",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "948f206e1cf94cf29f7ead73d29876bd",
          "Name": "",
          "Description": "Set_X",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "345249146d7c49f287106731d27bc874",
          "Name": "",
          "Description": "Set_Y",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "030ec60d2f8e499eb5383f1154025888",
          "Name": "",
          "Description": "Jt_A",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "bb9482d349434e65a5506dcce063592f",
          "Name": "",
          "Description": "Jt_B",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2044fbd1563244358943038ee42fbdd9",
          "Name": "",
          "Description": "Jt_C",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3043d537d76d4394ad4a31c9e7d682bb",
          "Name": "",
          "Description": "Jt_D",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "7007011fae4f401489c6d5fa52fb6f48",
          "Name": "",
          "Description": "Jt_Info",
          "UsingDefaultValue": false,
