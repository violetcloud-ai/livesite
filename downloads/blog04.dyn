    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "//Joint Data = [Name, Restraint (F=Free), Coord (XYZ mm), Jt Forces (kN)]\nSet_X = 0;\nSet_Y = 0;\nJt_A = [\"A\", [\"R\", \"R\", \"R\"], [Set_X + 0, Set_Y, 0], [0, 0, 0]];\nJt_B = [\"B\", [\"F\", \"F\", \"F\"], [Set_X + 6000, Set_Y, 4500], [0, 0, 0]];\nJt_C = [\"C\", [\"R\", \"R\", \"R\"], [Set_X + 12000, Set_Y, 4500], [0, 0, 0]];\nJt_Info = [Jt_B, Jt_A, Jt_C];\n\n//Material Property = [Elastic Mod MPa, MOI mm4, Area mm2]\nE_m = 200000;\nI_m = 60*1000000;\nA_m = 600;\nProp = [E_m, A_m, I_m];\n\n//Member data = [Name, Jt_i, Jt_j, UDL (kN/m), Material Property]\nMbr_1 = [\"Mbr 1\", \"A\", \"B\", 0.0, Prop];\nMbr_2 = [\"Mbr 2\", \"B\", \"C\", 3.0, Prop];\nMbr_Info = [Mbr_1, Mbr_2];\n\n//Input Summary\nInput = [Jt_Info, Mbr_Info];",
      "Id": "b6fe5aadd07e453088451d90e0e8a5c8",
