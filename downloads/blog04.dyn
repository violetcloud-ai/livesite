    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Enable Python support and load DesignScript library\r\nimport clr\r\nimport math\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ndataEnteringNode = IN\r\n\r\n# Place your code below this line\r\nSize = IN[0]\r\nRad = IN[1]\r\nAO = [-10000, 0, 0] #Axis_Origin\r\n\r\nP_0 = Point.ByCoordinates(AO[0], AO[1], AO[2])\r\nP_X = Point.ByCoordinates(AO[0] + Size, AO[1], AO[2])\r\nP_Y = Point.ByCoordinates(AO[0], AO[1] + Size, AO[2])\r\nP_Z = Point.ByCoordinates(AO[0], AO[1], AO[2] + Size)\r\n\r\nC_X = Cylinder.ByPointsRadius(P_0, P_X, Rad)\r\nC_Y = Cylinder.ByPointsRadius(P_0, P_Y, Rad)\r\nC_Z = Cylinder.ByPointsRadius(P_0, P_Z, Rad)\r\nC_0 = Sphere.ByCenterPointRadius(P_0, Rad*2)\r\n\r\nXYZ_Axes = [C_X, C_Y, C_Z, C_0]\r\n\r\n# Assign your output to the OUT variable.\r\nOUT = XYZ_Axes",
      "VariableInputPorts": true,
      "Id": "f728670560d842a5aeb2f6e849aa6f83",
      "Inputs": [
        {
          "Id": "55f2c2e5151d4c1fbc5374f7c06d33d8",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "9fb591dd02da4bbe95c5f428820ddab2",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "9f76713e3f6d468a91a16601574e4b9d",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded IronPython script."
    },
