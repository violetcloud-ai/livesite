    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "//Joint Data = [Name, Restraint (F=Free), Coord (XYZ mm), Jt PVM (kN,kN,kNm)]\nSet_X = 0;\nSet_Y = 0;\nJt_A = [\"A\", [\"R\", \"R\", \"R\"], [Set_X + 0, Set_Y, 0], [0, 0, 0]];\nJt_B = [\"B\", [\"F\", \"F\", \"F\"], [Set_X + 0, Set_Y, 5000], [0, 0, 0]];\nJt_C = [\"C\", [\"F\", \"F\", \"F\"], [Set_X + 0, Set_Y, 10000], [0, 0, 0]];\nJt_D = [\"D\", [\"F\", \"F\", \"F\"], [Set_X + 0, Set_Y, 15000], [0, 0, 0]];\nJt_E = [\"E\", [\"R\", \"R\", \"R\"], [Set_X + 5000, Set_Y, 0], [0, 0, 0]];\nJt_F = [\"F\", [\"F\", \"F\", \"F\"], [Set_X + 5000, Set_Y, 5000], [5, 0, 0]];\nJt_G = [\"G\", [\"F\", \"F\", \"F\"], [Set_X + 5000, Set_Y, 10000], [5, 0, 0]];\nJt_H = [\"H\", [\"F\", \"F\", \"F\"], [Set_X + 5000, Set_Y, 15000], [5, 0, 0]];\nJt_Info = [Jt_A, Jt_B, Jt_C, Jt_D, Jt_E, Jt_F, Jt_G, Jt_H];\n\n//Material Property = [Elastic Mod MPa, MOI mm4, Area mm2]\nE_m = 200000;\nI_m = 60*1000000;\nA_m = 600;\nProp = [E_m, A_m, I_m];\n\n//Member data = [Jt_i, Jt_j, UDL (kN/m), Material Property]\nMbr_1 = [\"Mbr 1\", \"A\", \"B\", 0.0, Prop];\nMbr_2 = [\"Mbr 2\", \"B\", \"C\", 0.0, Prop];\nMbr_3 = [\"Mbr 3\", \"C\", \"D\", 0.0, Prop];\nMbr_4 = [\"Mbr 4\", \"E\", \"F\", 0.0, Prop];\nMbr_5 = [\"Mbr 5\", \"F\", \"G\", 0.0, Prop];\nMbr_6 = [\"Mbr 6\", \"G\", \"H\", 0.0, Prop];\nMbr_7 = [\"Mbr 7\", \"B\", \"F\", 0.0, Prop];\nMbr_8 = [\"Mbr 8\", \"C\", \"G\", 0.0, Prop];\nMbr_9 = [\"Mbr 9\", \"D\", \"H\", 0.0, Prop];\nMbr_Info = [Mbr_1, Mbr_2, Mbr_3, Mbr_4, Mbr_5, Mbr_6, Mbr_7, Mbr_8, Mbr_9];\n\n//Input Summary\nInput = [Jt_Info, Mbr_Info];",
